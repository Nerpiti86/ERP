# ============================================================
# ERP - .gitignore
# Proyecto Django local con PostgreSQL y acceso por Tailscale
# ============================================================

# ------------------------------------------------------------
# Logs locales de trabajo
# ------------------------------------------------------------
logs/

# ------------------------------------------------------------
# Variables de entorno y secretos
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.pfx
*.p12
secrets/
credentials/
credenciales/

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ------------------------------------------------------------
# Entornos virtuales
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------
# Django
# ------------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# ------------------------------------------------------------
# PostgreSQL / backups / dumps
# ------------------------------------------------------------
backups/
*.dump
*.backup
*.sql
*.sql.gz
*.psql

# ------------------------------------------------------------
# Archivos subidos / documentos locales
# ------------------------------------------------------------
uploads/
private_media/
documentos_locales/

# ------------------------------------------------------------
# Caches y herramientas Python
# ------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/
coverage.xml
*.cover
*.py,cover

# ------------------------------------------------------------
# Build / packaging
# ------------------------------------------------------------
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------
# Jupyter / notebooks temporales
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# IDEs y editores
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ------------------------------------------------------------
# Sistema operativo
# ------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------
# Windows temporales
# ------------------------------------------------------------
*.tmp
*.temp
~$*
*.bak

# ------------------------------------------------------------
# Node / frontend futuro
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.parcel-cache/
.next/
vite.config.ts.timestamp-*
vite.config.js.timestamp-*

# ------------------------------------------------------------
# Archivos locales de ejecucion
# ------------------------------------------------------------
*.pid
*.seed
*.pid.lock

# ------------------------------------------------------------
# No ignorar documentacion versionable
# ------------------------------------------------------------
!docs/
!docs/**/*.md
